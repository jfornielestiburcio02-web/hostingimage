{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/index.php",
      "dest": "/api/index.php"
    },
    {
      "src": "/sempresa/",
      "dest": "/api/sempresa/index.php"
    },
    {
      "src": "/ayudas/ayudaconapis.html",
      "dest": "/api/ayudas/ayudaconapis.html"
    },
    {
      "src": "/en/sempresa/",
      "dest": "/api/en/sempresa/index.php"
    },
    {
      "src": "/es/",
      "dest": "/api/es/index.php"
    },
    {
      "src": "/sempresa/index.php",
      "status": 404
    },
    {
      "src": "/en/index.php",
      "status": 404
    },
    {
      "src": "/en/",
      "dest": "/api/en/index.php"
    },
    {
      "src": "/(.*)\\.php",
      "dest": "/api/$1.php"
    },
    {
      "src": "/(.*)\\.xlx",
      "status": 404
    },
    {
      "src": ".env",
      "dest": "/noPermitido.html"
    },
    {
      "src": "/imagenes/(.*)",
      "dest": "https://raw.githubusercontent.com/jfornielestiburcio02-web/hostingimage/main/imagenes/$1"
    }
  ]
}
